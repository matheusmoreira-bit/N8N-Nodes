{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",               // compila mantendo a estrutura de pastas
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "nodes/**/*.ts",
    "credentials/**/*.ts"
  ],
  "exclude": [
    "nodes/ERPSAPB1/actions/integration/**/*",
    "nodes/ERPSAPB1/methods/**/*",
    "nodes/ERPSAPB1/transport/ERPSAPB1Parser.ts"
  ]
}
